{
  "name": "ventanex-qe-cypress",
  "version": "1.0.0",
  "description": "Cypress Automation Framework",
  "author": "Jeff Hamblen, Khannara Phay",
  "scripts": {
    "api:all": "cypress run --spec cypress/tests/api/*/*/*.cy.js",
    "api:hesc": "cypress run --spec cypress/tests/api/servicemac/*/*.cy.js",
    "api:lauch": "cypress run --spec cypress/tests/api/launch/*/*.cy.js",
    "api:servicemac": "cypress run --spec cypress/tests/api/servicemac/*/*.cy.js",
    "api:usbank": "cypress run --spec cypress/tests/api/usbank/*/*.cy.js",
    "api:vhda": "cypress run --spec cypress/tests/api/vhda/*/*.cy.js",
    "cypress:open:localhost": "ENV=localhost npm run cypress:open",
    "cypress:open:dev": "ENV=dev npm run cypress:open",
    "cypress:open:qa": "ENV=qa npm run cypress:open",
    "cypress:open": "cypress open",
    "start:ci": "serve --no-clipboard --listen ${PORT:-8080}"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.0.2",
    "cypress": "^13.2.0",
    "cypress-mochawesome-reporter": "^3.8.1"
  },
  "dependencies": {
    "moment": "^2.29.4"
  }
}
