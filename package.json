{
  "name": "ventanex-qe-cypress",
  "version": "1.0.0",
  "description": "Cypress Automation Framework",
  "author": "Jeff Hamblen, Khannara Phay",
  "scripts": {
    "start:ci": "serve --no-clipboard --listen ${PORT:-8080}",
    "cypress:open:localhost": "ENV=localhost npm run cypress:open",
    "cypress:open:dev": "ENV=dev npm run cypress:open",
    "cypress:open:qa": "ENV=qa npm run cypress:open",
    "cypress:open": "cypress open",
    "api:all": "npx cypress run --spec cypress/tests/api/*/*/*.cy.js",
    "api:hesc": "npx cypress run --spec cypress/tests/api/servicemac/*/*.cy.js",
    "api:lauch": "npx cypress run --spec cypress/tests/api/launch/*/*.cy.js",
    "api:servicemac": "npx cypress run --spec cypress/tests/api/servicemac/*/*.cy.js",
    "api:usbank": "npx cypress run --spec cypress/tests/api/usbank/*/*.cy.js",
    "api:vhda": "npx cypress run --spec cypress/tests/api/vhda/*/*.cy.js"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.0.2",
    "cypress": "^13.2.0",
    "cypress-mochawesome-reporter": "^3.3.0",
    "cypress-multi-reporters": "^1.6.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.2.2",
    "mochawesome-report-generator": "^6.2.0"
  },
  "dependencies": {
    "moment": "^2.29.4"
  }
}
